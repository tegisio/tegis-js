# Tegis quickstart config. Copy to `.env` and fill in from your Tegis tenant onboarding.
# `bun` auto-loads .env.

# 32-byte Ed25519 signing seed, base64url — SERVER-ONLY. Never commit, log, or send to the browser.
TEGIS_SIGN_SEED=

# Your tenant identity (from onboarding)
TEGIS_TID=t_yourtenant
TEGIS_KID=k1
TEGIS_ISSUER=https://yourapp.example

# Your tenant endpoints (the CNAME Tegis gives you).
TEGIS_MINT_URL=https://your-tenant.tegis.io
TEGIS_EDGE_URL=https://your-tenant.tegis.io

# Handshake secret Tegis delivered (base64url). Production: prefer the WASM-whitened handshake instead
# (no secret in the browser) — see the @tegis/player README.
TEGIS_HANDSHAKE_SECRET=

# Local server port
PORT=3000
